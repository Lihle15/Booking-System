@model BookingSystem.Models.DoctorModel

<h2>Create Doctor</h2>

<form asp-action="CreateDoctor" asp-controller="Admin" method="post">
    <div class="form-group">
        <label asp-for="Name">Doctor Name</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Specialty">Specialty</label>
        <input asp-for="Specialty" class="form-control" />
        <span asp-validation-for="Specialty" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Availability">Availability</label>
        <input asp-for="Availability" class="form-control" />
        <span asp-validation-for="Availability" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="ContactDetails">Contact Details</label>
        <input asp-for="ContactDetails" class="form-control" />
        <span asp-validation-for="ContactDetails" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Create Doctor</button>
</form>

<a href="@Url.Action("ManageDoctors", "Admin")" class="btn btn-secondary w-100">Cancel</a>
<br />

