<h2>Admin Dashboard</h2>
<h3 class="text-center">Welcome admin, please select what you want to do</h3>

<br />

<div class="row">
    <div class="col-md-6">
        <div class="card equal-height">
            <div class="card-header">
                <h4>Manage Patients</h4>
            </div>
            <div class="card-body" text-center>
                <p>View, create, update, or delete patient accounts.</p>
                <a href="@Url.Action("ManagePatients", "Admin")" class="btn btn-primary">Manage Patients</a>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card equal-height">
            <div class="card-header">
                <h4>Manage Doctors</h4>
            </div>
            <div class="card-body">
                <p>View, create, update, or delete doctor profiles, including specialties and availability.</p>
                <a href="@Url.Action("ManageDoctors", "Admin")" class="btn btn-primary">Manage Doctors</a>
            </div>
        </div>
    </div>
</div>

<div class="row mt-3">
    <div class="col-md-6">
        <div class="card equal-height">
            <div class="card-header">
                <h4>View Appointments</h4>
            </div>
            <div class="card-body">
                <p>View all scheduled appointments and their statuses.</p>
                <a href="@Url.Action("ViewAppointments", "Admin")" class="btn btn-primary">View Appointments</a>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card equal-height">
            <div class="card-header">
                <h4>Send Email Reminders</h4>
            </div>
            <div class="card-body">
                <p>Send reminders to patients 24 hours before their appointments.</p>
                <a href="@Url.Action("SendReminders", "Admin")" class="btn btn-primary">Send Reminders</a>
            </div>
        </div>
    </div>
</div>

<div class="row mt-3">
    <div class="col-md-6">
        <div class="card equal-height">
            <div class="card-header">
                <h4>Manage Appointments</h4>
            </div>
            <div class="card-body">
                <p>View, reschedule, or cancel appointments.</p>
                <a href="@Url.Action("ViewAllAppointments", "Admin")" class="btn btn-primary">Manage Appointments</a>
            </div>
        </div>
    </div>
</div>


