@model BookingSystem.Models.Patient

<h2>Edit Patient Details</h2>

<form asp-action="EditPatient" method="post">
    <div class="form-group">
        <label asp-for="Username"><strong>Username</strong></label>
        <input asp-for="Username" class="form-control" />
        <span asp-validation-for="Username" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Password"><strong>Password</strong></label>
        <input asp-for="Password" class="form-control" type="password" />
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Name"><strong>First Name</strong></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Surname"><strong>Last Name</strong></label>
        <input asp-for="Surname" class="form-control" />
        <span asp-validation-for="Surname" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Email"><strong>Email</strong></label>
        <input asp-for="Email" class="form-control" type="email" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="PhoneNo"><strong>Phone Number</strong></label>
        <input asp-for="PhoneNo" class="form-control" />
        <span asp-validation-for="PhoneNo" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="DateOfBirth"><strong>Date of Birth</strong></label>
        <input asp-for="DateOfBirth" class="form-control" type="date" />
        <span asp-validation-for="DateOfBirth" class="text-danger"></span>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <button type="submit" class="btn btn-primary w-100">Save Changes</button>
        </div>
        <div class="col-md-6">
            <a href="@Url.Action("ManagePatients")" class="btn btn-secondary w-100">Back to Patient List</a>
        </div>
    </div>
</form>


