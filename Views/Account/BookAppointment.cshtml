            alert("Please select a time between 09:00 and 16:30.");
            appointmentTimeInput.value = '';
        }

        
        if (minutes % 30 !== 0) {
            alert("Please select a time in 30-minute increments.");
            appointmentTimeInput.value = ''; 
        }
    });
</script>

