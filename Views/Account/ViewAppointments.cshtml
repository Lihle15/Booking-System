@model IEnumerable<BookingSystem.Models.Appointment>

@{
    ViewData["Title"] = "View Appointments";
}

<h2>Your Appointments</h2>

<table class="table">
    <thead>
        <tr>
            <th>Date</th>
            <th>Time</th>
            <th>Doctor</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var appointment in Model)
        {
            <tr>
                <td>@appointment.AppointmentDate.ToString("d")</td>
                <td>@appointment.AppointmentTime.ToString(@"hh\:mm")</td>
                <td>@appointment.SelectedDoctor</td>
                <td>@appointment.Status</td>
            </tr>
        }
    </tbody>
</table>
<div class="text-center">
    <a href="@Url.Action("Dashboard", "Account")" class="btn btn-primary">Return to Dashboard</a>
</div>

